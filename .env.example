# ===== Binance API =====
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here
BINANCE_SANDBOX=true

# ===== Trading Behavior =====
# اغلاق الصفقة عند أول ربح بسيط (0.1%)
CLOSE_ON_MIN_PROFIT=true
MIN_PROFIT_CLOSE_PCT=0.001

# إضافة العملات الموجودة في الرصيد تلقائيًا إلى الفحص (مثل BTC -> BTC/USDT)
SCAN_BALANCE_COINS=true
BALANCE_QUOTE_ASSET=USDT
BALANCE_QUOTE_ASSETS=USDT,BNB,LTC
BALANCE_COIN_MIN_TOTAL=0.0
MAX_BALANCE_SCAN_PAIRS=20

# في وضع Spot: عند إشارة SELL يمكن البيع من رصيد العملة نفسها (مثل LTC في زوج LTC/USDT)
SPOT_INVENTORY_SELL_ENABLED=true
SPOT_INVENTORY_SELL_RATIO=0.35
MAX_CAPITAL_PER_TRADE=0.35

# نقل تلقائي (اختياري) من Funding Wallet إلى Spot Wallet قبل التشغيل
AUTO_TRANSFER_FUNDING_TO_SPOT=false
FUNDING_TRANSFER_ASSETS=BNB
FUNDING_TRANSFER_MIN_FREE=0.00001

# ===== Telegram Bot =====
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ===== MySQL Database =====
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=trading_bot

# ===== Encryption =====
ENCRYPTION_KEY=your_fernet_key_here
